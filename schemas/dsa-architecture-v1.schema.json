{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tonibohnlein/dsa-solver/schemas/dsa-architecture-v1.schema.json",
  "title": "DSA architecture specification schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "architecture_id",
    "supported_lowering_abis",
    "metadata",
    "memory_spaces"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "architecture_id": {
      "type": "string",
      "minLength": 1
    },
    "supported_lowering_abis": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "memory_spaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/memory_space"
      }
    }
  },
  "$defs": {
    "uint64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "positive_uint32": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4294967295
    },
    "positive_uint64": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18446744073709551615
    },
    "address_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["begin", "end"],
      "properties": {
        "begin": {"$ref": "#/$defs/uint64"},
        "end": {"$ref": "#/$defs/uint64"}
      }
    },
    "bank_geometry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bank_size", "num_banks"],
      "properties": {
        "bank_size": {"$ref": "#/$defs/positive_uint64"},
        "num_banks": {"$ref": "#/$defs/positive_uint32"}
      }
    },
    "memory_space": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_space",
        "usable_capacity",
        "physical_capacity",
        "minimum_alignment",
        "reserved_ranges"
      ],
      "properties": {
        "logical_space": {
          "type": "string",
          "minLength": 1
        },
        "usable_capacity": {
          "$ref": "#/$defs/positive_uint64"
        },
        "physical_capacity": {
          "oneOf": [
            {"$ref": "#/$defs/uint64"},
            {"type": "null"}
          ]
        },
        "minimum_alignment": {
          "$ref": "#/$defs/positive_uint64"
        },
        "reserved_ranges": {
          "type": "array",
          "items": {"$ref": "#/$defs/address_range"}
        },
        "bank_geometry": {
          "$ref": "#/$defs/bank_geometry"
        }
      }
    }
  }
}
