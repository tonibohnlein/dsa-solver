{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tonibohnlein/dsa-solver/schemas/dsa-problem-v1.schema.json",
  "title": "DSA structured problem schema v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "instance",
    "problem"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "profile": {
      "enum": [
        "standard_dsa",
        "pypto_structured",
        "pypto_core_relaxation"
      ]
    },
    "instance": {
      "type": "string",
      "minLength": 1
    },
    "relaxed_from": {
      "type": "string",
      "minLength": 1
    },
    "relaxed_features": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "problem": {
      "$ref": "#/$defs/problem"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "const": "pypto_core_relaxation"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "required": [
          "relaxed_from"
        ]
      },
      "else": {
        "not": {
          "anyOf": [
            {
              "required": [
                "relaxed_from"
              ]
            },
            {
              "required": [
                "relaxed_features"
              ]
            }
          ]
        }
      }
    }
  ],
  "$defs": {
    "uint32": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4294967295
    },
    "uint64": {
      "type": "integer",
      "minimum": 0,
      "maximum": 18446744073709551615
    },
    "pair": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first",
        "second"
      ],
      "properties": {
        "first": {
          "$ref": "#/$defs/uint32"
        },
        "second": {
          "$ref": "#/$defs/uint32"
        }
      }
    },
    "separation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first",
        "second"
      ],
      "properties": {
        "first": {
          "$ref": "#/$defs/uint32"
        },
        "second": {
          "$ref": "#/$defs/uint32"
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "generic",
              "pipeline_stage",
              "target_hazard",
              "semantic_no_alias"
            ]
          }
        }
      }
    },
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lower",
        "upper"
      ],
      "properties": {
        "lower": {
          "type": "integer"
        },
        "upper": {
          "type": "integer"
        }
      }
    },
    "address_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "begin",
        "end"
      ],
      "properties": {
        "begin": {
          "$ref": "#/$defs/uint64"
        },
        "end": {
          "$ref": "#/$defs/uint64"
        }
      }
    },
    "pool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "capacity",
        "reserved_ranges"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/uint32"
        },
        "name": {
          "type": "string"
        },
        "capacity": {
          "oneOf": [
            {
              "$ref": "#/$defs/uint64"
            },
            {
              "type": "null"
            }
          ]
        },
        "reserved_ranges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/address_range"
          }
        },
        "bank_geometry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "bank_size",
            "num_banks"
          ],
          "properties": {
            "bank_size": {
              "$ref": "#/$defs/uint64"
            },
            "num_banks": {
              "$ref": "#/$defs/uint32"
            }
          }
        }
      }
    },
    "buffer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "size",
        "alignment",
        "live_intervals",
        "allowed_pools"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/uint32"
        },
        "name": {
          "type": "string"
        },
        "size": {
          "$ref": "#/$defs/uint64"
        },
        "alignment": {
          "$ref": "#/$defs/uint64"
        },
        "live_intervals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/interval"
          }
        },
        "allowed_pools": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/uint32"
          }
        }
      }
    },
    "pinned_allocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "buffer",
        "pool",
        "offset",
        "exclusive_for_all_time"
      ],
      "properties": {
        "buffer": {
          "$ref": "#/$defs/uint32"
        },
        "pool": {
          "$ref": "#/$defs/uint32"
        },
        "offset": {
          "$ref": "#/$defs/uint64"
        },
        "exclusive_for_all_time": {
          "type": "boolean"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "colocations",
        "separations",
        "temporal_exclusions",
        "pinned_allocations"
      ],
      "properties": {
        "colocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pair"
          }
        },
        "separations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/separation"
          }
        },
        "temporal_exclusions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pair"
          }
        },
        "pinned_allocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pinned_allocation"
          }
        }
      }
    },
    "reuse_penalty": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "first",
        "second",
        "cost",
        "reason"
      ],
      "properties": {
        "first": {
          "$ref": "#/$defs/uint32"
        },
        "second": {
          "$ref": "#/$defs/uint32"
        },
        "cost": {
          "$ref": "#/$defs/uint64"
        },
        "reason": {
          "enum": [
            "generic",
            "cross_pipe",
            "cross_core",
            "event_budget"
          ]
        }
      }
    },
    "cost_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reuse_penalties"
      ],
      "properties": {
        "reuse_penalties": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reuse_penalty"
          }
        }
      }
    },
    "pypto_alias_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "buffer",
        "members"
      ],
      "properties": {
        "buffer": {
          "$ref": "#/$defs/uint32"
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pypto_pipeline_member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "buffer",
        "stage",
        "residue"
      ],
      "properties": {
        "buffer": {
          "$ref": "#/$defs/uint32"
        },
        "stage": {
          "$ref": "#/$defs/uint32"
        },
        "residue": {
          "$ref": "#/$defs/uint32"
        }
      }
    },
    "pypto_pipeline_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group",
        "pool",
        "slot_size",
        "depth",
        "effective_depth",
        "members"
      ],
      "properties": {
        "group": {
          "$ref": "#/$defs/uint32"
        },
        "pool": {
          "$ref": "#/$defs/uint32"
        },
        "slot_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 18446744073709551615
        },
        "depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        },
        "effective_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        },
        "members": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pypto_pipeline_member"
          }
        }
      }
    },
    "pypto_structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alias_classes",
        "pipeline_groups"
      ],
      "properties": {
        "whole_slot_reuse": {
          "type": "boolean",
          "default": false
        },
        "alias_classes": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pypto_alias_class"
          }
        },
        "pipeline_groups": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/pypto_pipeline_group"
          }
        }
      }
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregation",
        "terms"
      ],
      "properties": {
        "aggregation": {
          "const": "lexicographic"
        },
        "terms": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "capacity_overflow",
              "total_peak",
              "max_peak",
              "reuse_cost",
              "bank_cost"
            ]
          }
        }
      }
    },
    "problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pools",
        "buffers",
        "constraints",
        "objective"
      ],
      "properties": {
        "pools": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pool"
          }
        },
        "buffers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/buffer"
          }
        },
        "constraints": {
          "$ref": "#/$defs/constraints"
        },
        "cost_model": {
          "$ref": "#/$defs/cost_model"
        },
        "pypto_structure": {
          "$ref": "#/$defs/pypto_structure"
        },
        "objective": {
          "$ref": "#/$defs/objective"
        }
      }
    }
  }
}
